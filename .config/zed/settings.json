{
  "git_panel": {
    "tree_view": false,
  },
  "agent_servers": {
    "qwen-code": {
      "type": "custom",
      "command": "qwen",
      "args": ["--acp"],
      "env": {},
    },
  },
  "calls": {
    "share_on_join": true,
    "mute_on_join": false,
  },
  "audio": {
    "experimental.auto_speaker_volume": true,
    "experimental.denoise": true,
    "experimental.legacy_audio_compatible": true,
    "experimental.rodio_audio": true,
    "experimental.auto_microphone_volume": true,
  },
  "excerpt_context_lines": 4,
  "ui_font_family": "Monaspace Argon NF",
  "buffer_font_weight": 400.0,
  "agent": {
    "default_profile": "write",
    "default_model": {
      "enable_thinking": true,
      "provider": "ollama",
      "model": "deepseek-r1:8b",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "snippet_sort_order": "bottom",
  "indent_guides": {
    "coloring": "indent_aware",
  },
  "languages": {
    "Python": {
      "inlay_hints": {
        "enabled": true,
      },
      "format_on_save": "on",
      "indent_guides": {
        "coloring": "indent_aware",
        "background_coloring": "disabled",
      },
    },
  },
  "auto_signature_help": false,
  "show_signature_help_after_edits": false,
  "always_treat_brackets_as_autoclosed": false,
  "colorize_brackets": true,
  "redact_private_values": false,
  "relative_line_numbers": "disabled",
  "allow_rewrap": "in_comments",
  "preferred_line_length": 91,
  "show_wrap_guides": true,
  "edit_predictions": {
    "mode": "eager",
    "provider": "zed",
    "ollama": { "model": "deepseek-coder:6.7b",
                "prompt_format": "deepseek_coder" },
  },
  "horizontal_scroll_margin": 1.0,
  "scrollbar": {
    "axes": {
      "horizontal": true,
    },
  },
  "toolbar": {
    "code_actions": true,
  },
  "outline_panel": {
    "dock": "left",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "terminal": {
    "shell": {
      "program": "nu",
    },
    "font_size": 28.0,
    "cursor_shape": "bar",
  },
  "git": {
    "inline_blame": {
      "enabled": true,
    },
  },
  "base_keymap": "VSCode",
  "sticky_scroll": {
    "enabled": false,
  },
  "minimap": {
    "show": "never",
  },
  "cursor_blink": true,
  "autosave": "on_focus_change",
  "buffer_font_family": "Monaspace Neon NF",
  "soft_wrap": "editor_width",
  "icon_theme": "Material Icon Theme",
  "ui_font_size": 14.0,
  "buffer_font_size": 18.0,
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Dark",
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
      "padding": 2,
      "update_debounce_ms": 300,
    },
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "completion": {
          "snippits": {
            "custom": {
              "Enclose ok": {
                "postfix": "ok",
                "body": ["Ok(${receiver})"],
                "scope": "expr",
              },
            },
          },
        },
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "closureReturnTypeHints": {
            "enable": "always",
          },
        },
      },
    },
    "basedpyright": {
      "settings": {},
    },
  },
}
